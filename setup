#!/usr/bin/env bash
set -euo pipefail

FORGE_DIR="$(cd "$(dirname "$0")" && pwd)"
FORGE_HOME="$HOME/.forge"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${GREEN}[FORGE]${NC} $1"; }
warn()  { echo -e "${YELLOW}[FORGE]${NC} $1"; }
error() { echo -e "${RED}[FORGE]${NC} $1" >&2; }

echo ""
echo "  ╔═══════════════════════════════════╗"
echo "  ║     FORGE — Setup v1.0.0          ║"
echo "  ║     Claude Code Skill Framework   ║"
echo "  ╚═══════════════════════════════════╝"
echo ""

# Check for required tools
if ! command -v git &> /dev/null; then
    error "git is required but not installed."
    exit 1
fi

# Check for bun (preferred) or node
RUNTIME=""
if command -v bun &> /dev/null; then
    BUN_VERSION=$(bun --version 2>/dev/null || echo "0.0.0")
    MAJOR=$(echo "$BUN_VERSION" | cut -d. -f1)
    if [ "$MAJOR" -ge 1 ]; then
        RUNTIME="bun"
        info "Found Bun v${BUN_VERSION}"
    else
        warn "Bun found but version $BUN_VERSION is too old (need 1.0+)"
    fi
fi

if [ -z "$RUNTIME" ] && command -v node &> /dev/null; then
    NODE_VERSION=$(node --version 2>/dev/null | sed 's/v//')
    RUNTIME="node"
    info "Found Node.js v${NODE_VERSION}"
fi

if [ -z "$RUNTIME" ]; then
    warn "No Bun or Node.js found. FORGE skills are pure Markdown and will work, but /verify (Playwright) requires Node.js with npm."
elif [ "$RUNTIME" = "bun" ] && ! command -v node &> /dev/null; then
    warn "Bun found but Node.js/npm not detected. /verify uses npx for Playwright — install Node.js for full /verify support."
fi

# Create FORGE home directory
info "Creating FORGE home at ${FORGE_HOME}..."
mkdir -p "$FORGE_HOME/sessions"
mkdir -p "$FORGE_HOME/retros"

# Touch memory bank file
if [ ! -f "$FORGE_HOME/memory.jsonl" ]; then
    touch "$FORGE_HOME/memory.jsonl"
    info "Created empty memory bank at ${FORGE_HOME}/memory.jsonl"
else
    info "Memory bank already exists ($(wc -l < "$FORGE_HOME/memory.jsonl" | tr -d ' ') entries)"
fi

# Install skills to user's global Claude Code skills directory
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
info "Installing FORGE skills to ${CLAUDE_SKILLS_DIR}..."

# Install root bootstrap skill
if [ -f "$FORGE_DIR/SKILL.md" ]; then
    mkdir -p "$CLAUDE_SKILLS_DIR/forge"
    cp "$FORGE_DIR/SKILL.md" "$CLAUDE_SKILLS_DIR/forge/SKILL.md"
    info "  Installed /forge (bootstrap)"
fi

for skill_dir in "$FORGE_DIR"/skills/*/; do
    skill_name=$(basename "$skill_dir")

    # Handle nested skills (like memory/remember, memory/recall, memory/forget)
    if [ -d "$skill_dir" ]; then
        # Check for nested skill directories
        for nested_dir in "$skill_dir"*/; do
            if [ -f "${nested_dir}SKILL.md" ]; then
                nested_name=$(basename "$nested_dir")
                target_dir="$CLAUDE_SKILLS_DIR/${skill_name}-${nested_name}"
                mkdir -p "$target_dir"
                cp "${nested_dir}SKILL.md" "$target_dir/SKILL.md"
                info "  Installed /$(basename "$target_dir")"
            fi
        done

        # Also install the parent skill if it has a SKILL.md
        if [ -f "${skill_dir}SKILL.md" ]; then
            target_dir="$CLAUDE_SKILLS_DIR/$skill_name"
            mkdir -p "$target_dir"
            cp "${skill_dir}SKILL.md" "$target_dir/SKILL.md"
            info "  Installed /$skill_name"
        fi
    fi
done

# Summary
echo ""
info "Setup complete!"
echo ""
echo "  Skills installed to: $CLAUDE_SKILLS_DIR"
echo "  Memory bank at:      $FORGE_HOME/memory.jsonl"
echo "  Sessions dir:        $FORGE_HOME/sessions"
echo ""
echo "  Open Claude Code and type /think to start."
echo ""
